# ============================================
# CODEASSIST AI — CONFIGURATION
# ============================================
# Fill in your API keys below before starting the server.

# REQUIRED: Google Gemini API Key
# Get free at: https://ai.google.dev/gemini-api/docs/api-key
GEMINI_API_KEY=__PASTE_YOUR_GEMINI_API_KEY_HERE__

# OPTIONAL: OpenAI API Key (used as fallback for hard problems)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=__PASTE_YOUR_OPENAI_API_KEY_HERE__

# SERVER CONFIGURATION
PORT=3000
HOST=0.0.0.0

# AI MODEL CONFIGURATION
GEMINI_MODEL=gemini-2.0-flash
OPENAI_MODEL=gpt-4o

# PREFERRED CODING LANGUAGE for solutions
PREFERRED_LANGUAGE=Javascript, csharp, python, java, typescript

# CAPTURE SETTINGS
FRAME_INTERVAL_MS=3000
SIMILARITY_THRESHOLD=0.85
MAX_CONTEXT_MESSAGES=20
